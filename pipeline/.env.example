# Database — local Postgres via docker-compose
# Note: pipeline uses psycopg (sync) not asyncpg — COPY needs sync driver
DATABASE_URL=postgresql+psycopg://shelf:shelf@localhost:5432/shelf

# Cloudflare R2 — cover image storage, optional for local dev
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=shelf-covers
CLOUDFLARE_CDN_BASE_URL=

# Google Books API — cover fallback, optional (1000 req/day free tier)
GOOGLE_BOOKS_API_KEY=
