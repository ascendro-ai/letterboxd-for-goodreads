# Database — local Postgres via docker-compose
DATABASE_URL=postgresql+asyncpg://shelf:shelf@localhost:5432/shelf

# Environment — enables debug logging, Swagger docs, dev auth bypass
ENVIRONMENT=development

# Dev auth bypass — accepts "Bearer dev-user-<uuid>" tokens without JWT validation
# Only works when ENVIRONMENT=development. NEVER enable in production.
DEV_AUTH_BYPASS=true

# Supabase Auth — leave empty for local dev (dev auth bypass handles auth)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# Observability — optional, gracefully degrades when empty
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Cloudflare R2 — cover image storage, optional for local dev
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# External services — optional
BOOKSHOP_AFFILIATE_ID=
OPENAI_API_KEY=
